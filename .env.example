# Backend (Railway / local server.js)
GEMINI_API_KEY=
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-001
PORT=4000
PUBLIC_BASE_URL=https://api.10x.ai.kr

# Frontend (Vercel build)
VITE_API_BASE_URL=https://api.10x.ai.kr

# 분석 정책: 1=추측·짐작 금지(기본), 0=레거시(비권장)
ANALYSIS_ZERO_SPECULATION=1

# 선수 하이라이트: Modal 연결 시 GPU(soccer_best.pt) 우선. 0=CPU yolo11n 1차 (비권장)
PLAYER_GPU_FIRST=1

# Modal GPU (선수 추적·공 SAHI)
MODAL_ANALYZE_URL=
MODAL_AUTH_TOKEN=

# Phase A: SoccerNet action spotting (T-DEED, 슛/골 후보 시각 힌트)
MODAL_ACTION_SPOT_URL=
ACTION_SPOTTING_ENABLED=1
ACTION_SPOT_THRESHOLD=0.25
